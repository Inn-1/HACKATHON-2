<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MED+Search</title>

  <!--
    =====================================================
    FONTS
    We load two Google Fonts:
      - "DM Sans"          → used for regular text
      - "DM Serif Display" → used for big headings
    =====================================================
  -->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap');

    /* =====================================================
       CSS VARIABLES
    ===================================================== */
    :root {
      --navy:      #0d2045;   /* very dark blue */
      --blue:      #1e4db7;   /* medium blue */
      --bright:    #2563eb;   /* bright button blue */
      --light-blue:#dbeafe;   /* pale blue for badges */
      --pale:      #eff6ff;   /* very light blue background */
      --white:     #ffffff;
      --off-white: #f8faff;   /* slightly blue-tinted white */
      --border:    #e2ecff;   /* border colour */
      --text:      #0a1628;   /* almost-black text */
      --muted:     #4a5e80;   /* grey-blue for secondary text */
    }

    /* =====================================================
       RESET — removes default browser spacing so we
       have full control over how everything looks
    ===================================================== */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--off-white);
      color: var(--text);
      font-size: 15px;
      line-height: 1.5;
    }

    /* =====================================================
       LANGUAGE BAR — the dark strip at the very top
       that holds the language buttons
    ===================================================== */
    .lang-bar {
      background: #0a1628;
      padding: 0 32px;
      height: 38px;
      display: flex;
      align-items: center;
      justify-content: flex-end; /* push everything to the right */
      gap: 4px;
    }

    .lang-bar span {
      color: #93c5fd;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-right: 8px;
    }

    /* Each language button */
    .lang-btn {
      background: none;
      border: 1px solid transparent;
      border-radius: 4px;
      color: #bfdbfe;
      font-family: 'DM Sans', sans-serif;
      font-size: 12.5px;
      font-weight: 500;
      padding: 4px 10px;
      cursor: pointer;
    }

    /* Highlight button when hovered */
    .lang-btn:hover {
      border-color: #3b82f6;
      color: white;
    }

    /* The currently-selected language button looks filled-in */
    .lang-btn.active {
      background: var(--bright);
      border-color: var(--bright);
      color: white;
    }

    /* =====================================================
       HEADER — the big blue banner at the top
    ===================================================== */
    header {
      background: linear-gradient(160deg, #0d2045, #1a3a7c, #1e4db7);
      padding: 52px 32px 48px;
    }

    .header-inner {
      max-width: 1000px;
      margin: 0 auto; /* centre the content */
    }

    /* Small label above the main title */
    .eyebrow {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #93c5fd;
      margin-bottom: 14px;
    }

    header h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 4vw, 3rem); /* scales with screen width */
      color: white;
      margin-bottom: 14px;
      font-weight: 400;
    }

    header p {
      font-size: 15px;
      color: #bfdbfe;
      max-width: 520px;
      font-weight: 400;
    }

    /* =====================================================
       EMERGENCY BANNER — the row of hotline buttons
       below the header
    ===================================================== */
    .emergency-banner {
      background: white;
      border-bottom: 2px solid var(--light-blue);
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .emergency-inner {
      max-width: 1000px;
      margin: 0 auto;
      padding: 16px 32px;
      display: flex;
      flex-wrap: wrap;   /* wraps to next line on small screens */
      gap: 10px;
      align-items: center;
    }

    .emergency-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      margin-right: 8px;
    }

    /* Each hotline box (e.g. "Emergency Services / 911") */
    .hotline {
      display: flex;
      border: 1.5px solid var(--light-blue);
      border-radius: 6px;
      overflow: hidden; /* keeps the Call button corners rounded too */
    }

    .hotline-text {
      padding: 7px 14px;
      font-size: 12.5px;
      font-weight: 500;
      color: var(--text);
    }

    .hotline-text strong {
      display: block;
      font-size: 12px;
      font-weight: 700;
      color: var(--blue);
    }

    .hotline-text span {
      font-size: 11.5px;
      color: var(--muted);
    }

    /* The "Call Now" button attached to each hotline */
    .btn-call {
      background: var(--bright);
      color: white;
      border: none;
      padding: 0 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: flex;
      align-items: center;
      white-space: nowrap;
    }

    .btn-call:hover {
      background: var(--blue);
    }

    /* =====================================================
       MAIN CONTENT — centred wrapper for the search card
       and results table
    ===================================================== */
    main {
      max-width: 1000px;
      margin: 0 auto;
      padding: 32px 32px 80px;
    }

    /* Small uppercase label used above sections */
    .section-label {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--bright);
      margin-bottom: 10px;
    }

    /* =====================================================
       SEARCH CARD — the white box with filters
    ===================================================== */
    .search-card {
      background: white;
      border-radius: 10px;
      border: 1.5px solid var(--border);
      padding: 24px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      margin-bottom: 28px;
    }

    /* The row with the text input and Search button */
    .search-row {
      display: flex;
      gap: 10px;
      margin-bottom: 14px;
    }

    .search-row input {
      flex: 1; /* stretches to fill available space */
      padding: 10px 16px;
      border: 1.5px solid var(--border);
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      color: var(--text);
      background: var(--off-white);
      outline: none;
    }

    .search-row input:focus {
      border-color: #3b82f6; /* highlight when user clicks it */
      background: white;
    }

    .search-row input::placeholder {
      color: var(--muted);
    }

    /* The blue "Search" button */
    .btn-search {
      background: var(--bright);
      color: white;
      border: none;
      border-radius: 6px;
      padding: 10px 24px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }

    .btn-search:hover {
      background: var(--blue);
    }

    /* The row of dropdown filters */
    .filter-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .filter-row select {
      flex: 1;
      min-width: 150px;
      padding: 9px 12px;
      border: 1.5px solid var(--border);
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      color: var(--text);
      background: var(--off-white);
      cursor: pointer;
      outline: none;
    }

    .filter-row select:focus {
      border-color: #3b82f6;
    }

    /* "Clear All Filters" link/button */
    .reset-link {
      font-size: 12.5px;
      color: var(--muted);
      cursor: pointer;
      background: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      padding: 9px 0;
      text-decoration: underline;
      white-space: nowrap;
    }

    .reset-link:hover {
      color: var(--bright);
    }

    /* =====================================================
       RESULTS COUNT — "Showing 8 locations"
    ===================================================== */
    .results-bar {
      display: flex;
      align-items: center;
      margin-bottom: 12px;
    }

    .results-count {
      font-size: 13px;
      color: var(--muted);
      font-weight: 500;
    }

    /* =====================================================
       RESULTS TABLE — the main table of healthcare places
    ===================================================== */
    .results-table-wrap {
      background: white;
      border-radius: 10px;
      border: 1.5px solid var(--border);
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      overflow: hidden;
    }

    .results-table {
      width: 100%;
      border-collapse: collapse; /* removes gaps between cells */
    }

    /* Header row of the table */
    .results-table thead th {
      background: var(--pale);
      color: var(--blue);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      padding: 12px 16px;
      text-align: left;
      border-bottom: 1.5px solid var(--light-blue);
    }

    /* Each data row */
    .results-table tbody tr {
      border-bottom: 1px solid var(--border);
    }

    .results-table tbody tr:last-child {
      border-bottom: none; /* no line after the last row */
    }

    .results-table tbody tr:hover {
      background: var(--pale); /* light highlight on hover */
    }

    .results-table td {
      padding: 14px 16px;
      vertical-align: middle;
      font-size: 13.5px;
    }

    /* The location name and city below it */
    .cell-name .name {
      font-weight: 700;
      color: var(--text);
      font-size: 14px;
    }

    .cell-name .city {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }

    /* Coloured "type" badges like "Hospital" or "Walk-in Clinic" */
    .type-badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 4px;
      white-space: nowrap;
    }

    /* Each badge type gets its own colour */
    .badge-hospital      { background: var(--light-blue); color: var(--blue); }
    .badge-walk-in       { background: #dbeafe;           color: #1e40af; }
    .badge-mental-health { background: var(--pale);        color: var(--bright); border: 1px solid var(--light-blue); }
    .badge-pharmacy      { background: #e0f2fe;            color: #0369a1; }

    /* Distance cell (blue text) */
    .cell-dist {
      color: var(--bright);
      font-weight: 600;
    }

    /* Accessibility pills like "Wheelchair Access" */
    .access-pill {
      display: inline-block;
      font-size: 11.5px;
      font-weight: 500;
      color: var(--blue);
      background: var(--pale);
      border: 1px solid var(--light-blue);
      border-radius: 4px;
      padding: 2px 8px;
      margin: 2px 2px 2px 0;
    }

    /* The "Call" phone button in each row */
    .btn-phone {
      display: inline-block;
      border: 1.5px solid #93c5fd;
      color: var(--bright);
      border-radius: 6px;
      padding: 6px 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 12.5px;
      font-weight: 600;
      text-decoration: none;
      white-space: nowrap;
    }

    .btn-phone:hover {
      background: var(--bright);
      color: white;
      border-color: var(--bright);
    }

    /* The "Compare" checkbox label under the call button */
    .compare-label {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--muted);
      cursor: pointer;
      margin-top: 6px;
      font-weight: 500;
    }

    .compare-label input {
      accent-color: var(--bright);
      cursor: pointer;
    }

    /* Message shown when no results match the filters */
    .no-results {
      padding: 60px 20px;
      text-align: center;
      color: var(--muted);
      font-size: 14px;
    }

    .no-results strong {
      display: block;
      color: var(--text);
      font-size: 15px;
      margin-bottom: 6px;
    }

    /* =====================================================
       COMPARE SECTION — shown when 2 locations are checked
    ===================================================== */
    .compare-section {
      display: none; /* hidden by default; JS shows it */
      background: white;
      border-radius: 10px;
      border: 1.5px solid var(--light-blue);
      padding: 24px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      margin-top: 28px;
    }

    /* Side-by-side comparison table */
    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
      margin-top: 16px;
    }

    .compare-table th {
      background: var(--pale);
      color: var(--blue);
      font-weight: 700;
      font-size: 13px;
      padding: 11px 16px;
      text-align: left;
      border-bottom: 2px solid var(--light-blue);
    }

    .compare-table td {
      padding: 10px 16px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }

    .compare-table tr:last-child td {
      border-bottom: none;
    }

    /* First column (row labels like "Type", "Distance") */
    .compare-table td:first-child {
      color: var(--muted);
      font-weight: 600;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      width: 130px;
    }

    /* =====================================================
       FOOTER — the dark bar at the bottom
    ===================================================== */
    footer {
      background: #0a1628;
      padding: 20px 32px;
      text-align: center;
      font-size: 12px;
      color: #93c5fd;
    }

    /* =====================================================
       RESPONSIVE — on small screens, hide table headers
       and stack cells vertically instead
    ===================================================== */
    @media (max-width: 700px) {
      header, main         { padding-left: 16px; padding-right: 16px; }
      .lang-bar            { padding: 0 16px; }
      .emergency-inner     { padding: 12px 16px; }
      .search-row          { flex-direction: column; }
      .filter-row select   { min-width: 100%; }
      .results-table thead { display: none; }
      .results-table tbody tr { display: block; padding: 14px 16px; border-bottom: 1px solid var(--border); }
      .results-table td    { display: block; padding: 3px 0; border-bottom: none; }
    }
  </style>
</head>
<body>

  <!-- =====================================================
       LANGUAGE BAR
       Clicking a button calls setLang() with the language code.
  ===================================================== -->
  <div class="lang-bar">
    <span data-i18n="lang-select">Language:</span>
    <button class="lang-btn active" onclick="setLang('en')">English</button>
    <button class="lang-btn"        onclick="setLang('fr')">Français</button>
    <button class="lang-btn"        onclick="setLang('zh')">中文</button>
    <button class="lang-btn"        onclick="setLang('hi')">हिन्दी</button>
    <button class="lang-btn"        onclick="setLang('pa')">ਪੰਜਾਬੀ</button>
    <button class="lang-btn"        onclick="setLang('es')">Español</button>
  </div>

  <!-- =====================================================
       HEADER
  ===================================================== -->
  <header>
    <div class="header-inner">
      <div class="eyebrow" data-i18n="eyebrow">Health Services Directory — Canada</div>
      <h1 data-i18n="h1">MED+Search</h1>
      <p data-i18n="subhead">Locate hospitals, walk-in clinics, mental health resources, and pharmacies near you — anywhere in Canada.</p>
    </div>
  </header>

  <!-- =====================================================
       EMERGENCY BANNER
       Each hotline has a text block and a "Call Now" link.
  ===================================================== -->
  <div class="emergency-banner">
    <div class="emergency-inner">
      <span class="emergency-label" data-i18n="emergency-label">Emergency Contacts</span>

      <div class="hotline">
        <div class="hotline-text">
          <strong data-i18n="h-emergency">Emergency Services</strong>
          <span>911</span>
        </div>
        <a href="tel:911" class="btn-call" data-i18n="call-now">Call Now</a>
      </div>

      <div class="hotline">
        <div class="hotline-text">
          <strong data-i18n="h-mental">Mental Health Crisis</strong>
          <span data-i18n="h-mental-sub">Call or Text 988</span>
        </div>
        <a href="tel:988" class="btn-call" data-i18n="call-now2">Call Now</a>
      </div>

      <div class="hotline">
        <div class="hotline-text">
          <strong data-i18n="h-poison">Poison Control</strong>
          <span>1-800-268-9017</span>
        </div>
        <a href="tel:18002689017" class="btn-call" data-i18n="call-now3">Call Now</a>
      </div>

      <div class="hotline">
        <div class="hotline-text">
          <strong data-i18n="h-kids">Kids Help Phone</strong>
          <span>1-800-668-6868</span>
        </div>
        <a href="tel:18006686868" class="btn-call" data-i18n="call-now4">Call Now</a>
      </div>
    </div>
  </div>

  <!-- =====================================================
       MAIN CONTENT
  ===================================================== -->
  <main>

    <!-- Search Card -->
    <div class="search-card">
      <div class="section-label" data-i18n="search-label">Find Healthcare Near You</div>

      <!-- City search input + Search button -->
      <div class="search-row">
        <input
          type="text"
          id="locationInput"
          placeholder="Enter your city (e.g. Toronto, Vancouver, Montréal)"
          data-i18n-ph="search-ph"
        />
        <button class="btn-search" onclick="applyFilters()" data-i18n="search-btn">Search</button>
      </div>

      <!-- Four dropdown filters + Clear button -->
      <div class="filter-row">
        <select id="filterType" onchange="applyFilters()">
          <option value=""              data-i18n="f-all-types">All Types</option>
          <option value="hospital"      data-i18n="f-hospital">Hospital</option>
          <option value="walk-in"       data-i18n="f-walkin">Walk-in Clinic</option>
          <option value="mental-health" data-i18n="f-mental">Mental Health</option>
          <option value="pharmacy"      data-i18n="f-pharmacy">Pharmacy</option>
        </select>

        <select id="filterDistance" onchange="applyFilters()">
          <option value=""  data-i18n="f-any-dist">Any Distance</option>
          <option value="5"  data-i18n="f-5km">Within 5 km</option>
          <option value="10" data-i18n="f-10km">Within 10 km</option>
          <option value="20" data-i18n="f-20km">Within 20 km</option>
        </select>

        <select id="filterLang" onchange="applyFilters()">
          <option value="">Any Language</option>
          <option value="English">English</option>
          <option value="French">French</option>
          <option value="Mandarin">Mandarin</option>
          <option value="Punjabi">Punjabi</option>
          <option value="Spanish">Spanish</option>
        </select>

        <select id="filterAccess" onchange="applyFilters()">
          <option value=""           data-i18n="f-any-access">Any Accessibility</option>
          <option value="wheelchair" data-i18n="f-wheelchair">Wheelchair Access</option>
          <option value="parking"    data-i18n="f-parking">Accessible Parking</option>
        </select>

        <button class="reset-link" onclick="resetFilters()" data-i18n="reset">Clear All Filters</button>
      </div>
    </div>

    <!-- Shows how many results are visible -->
    <div class="results-bar">
      <div class="results-count" id="resultsCount">Showing all 8 locations</div>
    </div>

    <!-- Results Table -->
    <div class="results-table-wrap">
      <table class="results-table" id="resultsTable">
        <thead>
          <tr>
            <th data-i18n="col-name">Name</th>
            <th data-i18n="col-type">Type</th>
            <th data-i18n="col-dist">Distance</th>
            <th data-i18n="col-wait">Wait Time</th>
            <th data-i18n="col-langs">Languages</th>
            <th data-i18n="col-access">Accessibility</th>
            <th data-i18n="col-contact">Contact</th>
          </tr>
        </thead>
        <!-- Rows are generated by JavaScript below -->
        <tbody id="tableBody"></tbody>
      </table>
    </div>

    <!-- Compare Section (hidden until 2 locations are checked) -->
    <div class="compare-section" id="compareSection">
      <div class="section-label" data-i18n="compare-label">Side-by-Side Comparison</div>
      <table class="compare-table" id="compareTable"></table>
    </div>

  </main>


<!--FOOTER-->

  <footer>
    <p data-i18n="footer">Health Access Finder — Canada &nbsp;|&nbsp; This is a demonstration project. Always call 911 in an emergency.</p>
  </footer>


