      // Build accessibility pills (e.g. "Wheelchair Access")
      var accessHTML = '';
      for (var i = 0; i < loc.accessibility.length; i++) {
        accessHTML += '<span class="access-pill">' + getAccessLabel(loc.accessibility[i]) + '</span>';
      }

      // Is this location currently checked for comparison?
      var isChecked = compareList.indexOf(loc.id) !== -1;

      return (
        '<tr>' +
          '<td class="cell-name">' +
            '<div class="name">' + loc.name + '</div>' +
            '<div class="city">' + loc.city + '</div>' +
          '</td>' +
          '<td>' +
            '<span class="type-badge ' + getBadgeClass(loc.type) + '">' +
              getTypeLabel(loc.type) +
            '</span>' +
          '</td>' +
          '<td class="cell-dist">' + loc.distance + ' km</td>' +
          '<td>' + loc.waitTime + '</td>' +
          '<td style="color:var(--muted);font-size:13px">' + loc.languages.join(', ') + '</td>' +
          '<td>' + accessHTML + '</td>' +
          '<td>' +
            '<a href="tel:' + loc.phone + '" class="btn-phone">' +
              getText('call-btn') + ' ' + loc.phone +
            '</a>' +
            '<label class="compare-label">' +
              '<input type="checkbox" ' +
                'onchange="handleCompare(' + loc.id + ', this.checked)" ' +
                (isChecked ? 'checked' : '') + ' />' +
              getText('compare-btn') +
            '</label>' +
          '</td>' +
        '</tr>'
      );
    }

    /* -------------------------------------------------------
       7. APPLY FILTERS
       Reads the current values from all four dropdowns,
       then filters the locations array and re-renders the table.
    ------------------------------------------------------- */
    function applyFilters() {
      var typeFilter     = document.getElementById('filterType').value;
      var distanceFilter = document.getElementById('filterDistance').value;
      var langFilter     = document.getElementById('filterLang').value;
      var accessFilter   = document.getElementById('filterAccess').value;

      // Go through every location and keep only the ones that pass all filters
      var filtered = [];
      for (var i = 0; i < locations.length; i++) {
        var loc = locations[i];

        // Skip if type doesn't match (empty string means "any")
        if (typeFilter && loc.type !== typeFilter) continue;

        // Skip if distance is over the selected maximum
        if (distanceFilter && loc.distance > parseInt(distanceFilter)) continue;

        // Skip if this location doesn't offer the chosen language
        // .indexOf() returns -1 if the item is NOT in the array
        if (langFilter && loc.languages.indexOf(langFilter) === -1) continue;

        // Skip if this location doesn't have the chosen accessibility feature
        if (accessFilter && loc.accessibility.indexOf(accessFilter) === -1) continue;

        // All checks passed — include this location
        filtered.push(loc);
      }

      renderTable(filtered);
    }

    /* -------------------------------------------------------
       8. RESET FILTERS
       Clears all inputs and shows the full location list again.
    ------------------------------------------------------- */
    function resetFilters() {
      document.getElementById('locationInput').value = '';
      document.getElementById('filterType').value     = '';
      document.getElementById('filterDistance').value = '';
      document.getElementById('filterLang').value     = '';
      document.getElementById('filterAccess').value   = '';
      compareList = [];
      renderTable(locations);
      updateCompareSection();
    }

    /* -------------------------------------------------------
       9. COMPARE LOGIC
       Called when the user checks/unchecks a "Compare" checkbox.
       We allow a maximum of 2 locations to be compared at once.
    ------------------------------------------------------- */
    function handleCompare(id, isChecked) {
      if (isChecked) {
        // Only allow up to 2 locations
        if (compareList.length >= 2) {
          alert('You can only compare 2 locations at a time. Please deselect one first.');
          // Un-check the box (because we rejected the addition)
          document.getElementById('compare-' + id).checked = false;
          return;
        }
        compareList.push(id);
      } else {
        // Remove this id from the compareList
        var newList = [];
        for (var i = 0; i < compareList.length; i++) {
          if (compareList[i] !== id) {
            newList.push(compareList[i]);
          }
        }
        compareList = newList;
      }

      updateCompareSection();
    }

    /* -------------------------------------------------------
       10. UPDATE COMPARE SECTION
       Shows or hides the comparison table at the bottom.
       Only appears when exactly 2 locations are selected.
    ------------------------------------------------------- */
    function updateCompareSection() {
      var section = document.getElementById('compareSection');
      var table   = document.getElementById('compareTable');

      // Hide the section if we don't have exactly 2 locations selected
      if (compareList.length !== 2) {
        section.style.display = 'none';
        return;
      }

      // Find the two location objects by their id
      var locA = null;
      var locB = null;
      for (var i = 0; i < locations.length; i++) {
        if (locations[i].id === compareList[0]) locA = locations[i];
        if (locations[i].id === compareList[1]) locB = locations[i];
      }

      // Build the comparison table HTML
      table.innerHTML =
        '<thead><tr>' +
          '<th></th>' +
          '<th>' + locA.name + '</th>' +
          '<th>' + locB.name + '</th>' +
        '</tr></thead>' +
        '<tbody>' +
          '<tr><td>' + getText('type-lbl')  + '</td><td>' + getTypeLabel(locA.type)  + '</td><td>' + getTypeLabel(locB.type)  + '</td></tr>' +
          '<tr><td>' + getText('dist-lbl')  + '</td><td>' + locA.distance + ' km'    + '</td><td>' + locB.distance + ' km'    + '</td></tr>' +
          '<tr><td>' + getText('wait-lbl')  + '</td><td>' + locA.waitTime            + '</td><td>' + locB.waitTime            + '</td></tr>' +
          '<tr><td>' + getText('langs-lbl') + '</td><td>' + locA.languages.join(', ')+ '</td><td>' + locB.languages.join(', ')+ '</td></tr>' +
          '<tr><td>' + getText('access-lbl')+ '</td><td>' + locA.accessibility.map(getAccessLabel).join(', ') + '</td><td>' + locB.accessibility.map(getAccessLabel).join(', ') + '</td></tr>' +
          '<tr><td>' + getText('phone-lbl') + '</td><td>' + locA.phone              + '</td><td>' + locB.phone              + '</td></tr>' +
        '</tbody>';

      // Show the section and scroll to it
      section.style.display = 'block';
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    /* -------------------------------------------------------
       11. LANGUAGE SWITCHING
       Updates every element that has a data-i18n attribute
       with the translated text for the new language.
    ------------------------------------------------------- */
    function setLang(lang) {
      currentLang = lang;

      // Update which language button looks "active"
      var buttons = document.querySelectorAll('.lang-btn');
      for (var i = 0; i < buttons.length; i++) {
        buttons[i].classList.remove('active');
      }
      // Find the button for the chosen language and highlight it
      var allBtns = document.querySelectorAll('.lang-btn');
      for (var i = 0; i < allBtns.length; i++) {
        if (allBtns[i].getAttribute('onclick') === "setLang('" + lang + "')") {
          allBtns[i].classList.add('active');
        }
      }

      // Update every element that has a data-i18n="someKey" attribute
      var textEls = document.querySelectorAll('[data-i18n]');
      for (var i = 0; i < textEls.length; i++) {
        var key = textEls[i].getAttribute('data-i18n');
        textEls[i].textContent = getText(key);
      }

      // Update placeholder text (input fields use data-i18n-ph instead)
      var phEls = document.querySelectorAll('[data-i18n-ph]');
      for (var i = 0; i < phEls.length; i++) {
        var key = phEls[i].getAttribute('data-i18n-ph');
        phEls[i].placeholder = getText(key);
      }

      // Re-draw the table with the new language
      applyFilters();
    }

    /* -------------------------------------------------------
       12. START THE APP
       This line runs when the page loads.
       It draws the full table with all 8 locations.
    ------------------------------------------------------- */
    renderTable(locations);

  </script>
</body>
</html>

